# Copy this file to .env.local and fill in your Concert Costs project values.
# Supabase: open your project → Connect or Settings → API Keys
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - Publishable key (or legacy anon public key) → NEXT_PUBLIC_SUPABASE_ANON_KEY
# Do NOT use service role or secret keys here.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
